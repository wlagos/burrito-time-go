{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Burrito Time Go",
  "version": "1.0.0",
  "identifier": "com.base44.burrito-time-go",
  "app": {
    "windows": [
      {
        "title": "Burrito Time Go",
        "url": "https://burrito-time-go.base44.app",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
